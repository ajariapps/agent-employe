# Employee Monitoring Agent - Environment Variables
# Copy this file to .env and modify as needed

# Server Configuration
AGENT_SERVER_URL=http://localhost:8080
# AGENT_API_TOKEN=your_api_token_here

# Agent Configuration
# AGENT_HOSTNAME=my-computer
# AGENT_ID=your_agent_id_here

# Intervals (in seconds)
# AGENT_HEARTBEAT_SECS=30
# AGENT_ACTIVITY_SECS=60
# AGENT_SCREENSHOT_SECS=300

# Thresholds
# AGENT_IDLE_SECS=300

# Logging
AGENT_LOG_LEVEL=info
# AGENT_LOG_FORMAT=json

# Data Directories
# AGENT_DATA_DIR=/var/lib/agent-rust
# AGENT_LOG_DIR=/var/log/agent-rust

# Configuration File
# AGENT_CONFIG=/path/to/config.toml
